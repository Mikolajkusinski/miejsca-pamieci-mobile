{
  "API_BASE_URL": "https://<production-api-host>",
  "PROD": true,
  "COGNITO_USER_POOL_ID": "<from CDK stack outputs: UserPoolId>",
  "COGNITO_APP_CLIENT_ID": "<mobile app client id — create a dedicated one in the same user pool>",
  "COGNITO_REGION": "eu-central-1",
  "COGNITO_DOMAIN": "<e.g. memory-places.auth.eu-central-1.amazoncognito.com>"
}
